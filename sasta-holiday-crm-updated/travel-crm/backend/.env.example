# Copy this file to .env and fill in your own values.
# .env is in .gitignore — never commit real credentials.

# --- PostgreSQL connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sasta_holiday_crm
DB_USER=postgres
DB_PASSWORD=postgres

# --- Shared CRM login (used by everyone on the sales team) ---
CRM_USERNAME=admin
CRM_PASSWORD=sasta@123

# --- JWT secret (used to sign the login session token) ---
# Change this to any long random string in production.
JWT_SECRET=change_this_to_a_long_random_string

# --- Server ---
PORT=4000

# --- Twilio WhatsApp (trip reminders) ---
# From your Twilio Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Your approved WhatsApp sender number, in the format Twilio expects (with the
# "whatsapp:" prefix), e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# The SID of your Meta-approved template (Twilio Console > Messaging > Content Template Builder)
TWILIO_REMINDER_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to "false" to turn off the daily reminder job entirely (e.g. on a staging server)
WHATSAPP_REMINDERS_ENABLED=true
# Hour of the day (0-23, server local time) the daily reminder check runs
WHATSAPP_REMINDER_HOUR=9

